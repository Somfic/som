{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Som",
  "scopeName": "source.som",
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#keywords" },
    { "include": "#types" },
    { "include": "#function-definition" },
    { "include": "#struct-definition" },
    { "include": "#numbers" },
    { "include": "#operators" },
    { "include": "#punctuation" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.som",
          "match": "//.*$"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.som",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.som",
              "match": "\\\\."
            }
          ]
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.som",
          "match": "\\b(if|else|loop|while|for|use)\\b"
        },
        {
          "name": "keyword.other.som",
          "match": "\\b(fn|extern|struct|let|mut)\\b"
        },
        {
          "name": "constant.language.boolean.som",
          "match": "\\b(true|false)\\b"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "entity.name.type.primitive.som",
          "match": "\\b(i8|i16|i32|i64|i128|isize|u8|u16|u32|u64|u128|usize|f32|f64|bool|char|str)\\b"
        }
      ]
    },
    "function-definition": {
      "patterns": [
        {
          "match": "\\b(fn)\\s+([a-zA-Z_][a-zA-Z0-9_]*)\\s*\\(",
          "captures": {
            "1": { "name": "keyword.other.som" },
            "2": { "name": "entity.name.function.som" }
          }
        }
      ]
    },
    "struct-definition": {
      "patterns": [
        {
          "match": "\\b(struct)\\s+([a-zA-Z_][a-zA-Z0-9_]*)",
          "captures": {
            "1": { "name": "keyword.other.som" },
            "2": { "name": "entity.name.type.struct.som" }
          }
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.float.som",
          "match": "\\b[0-9]*\\.[0-9]+\\b"
        },
        {
          "name": "constant.numeric.integer.som",
          "match": "\\b[0-9]+\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.comparison.som",
          "match": "==|!=|<=|>=|<|>"
        },
        {
          "name": "keyword.operator.logical.som",
          "match": "&&|\\|\\||!"
        },
        {
          "name": "keyword.operator.arrow.som",
          "match": "->|=>"
        },
        {
          "name": "keyword.operator.assignment.som",
          "match": "="
        },
        {
          "name": "keyword.operator.arithmetic.som",
          "match": "[+\\-*/]"
        },
        {
          "name": "keyword.operator.borrow.som",
          "match": "&"
        }
      ]
    },
    "punctuation": {
      "patterns": [
        {
          "name": "punctuation.separator.som",
          "match": "::|[;:,.]"
        }
      ]
    }
  }
}
